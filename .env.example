# ============================================================================
# Patricks Calculator — omgevingsvariabelen
#
# LET OP: zonder deze variabelen draait de app in DEMO-MODUS met 3 voorgevulde
# contracten (in-memory, geen database nodig). Perfect om snel te checken.
# Kopieer dit bestand pas naar .env.local als je op een echte Supabase-database
# wilt draaien.
#
# Waar vind je deze waarden?
#   1. Ga naar https://supabase.com/dashboard en maak een nieuw project aan.
#   2. Draai de migraties uit supabase/migrations/ in de SQL-editor (op volgorde).
#   3. Project Settings -> API Keys voor de keys, Data API voor de URL.
# ============================================================================

# Project URL, bv. https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# De "publishable" key (begint met sb_publishable_...). Veilig voor de browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# De "secret" key (begint met sb_secret_...). ALLEEN server-side; nooit met
# NEXT_PUBLIC_ ervoor. Gebruikt door seed/benchmark-scripts en recompute-RPC's.
SUPABASE_SECRET_KEY=

# Publieke URL van de app (zonder slash op het eind).
NEXT_PUBLIC_SITE_URL=http://localhost:5290
